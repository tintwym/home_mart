APP_NAME="Home Mart"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# For local dev use http://127.0.0.1:8000 (php artisan serve is HTTP-only).
# In production use https:// (e.g. https://your-domain.com).
APP_URL=http://127.0.0.1:8000

# Vercel / production: set APP_URL (https://…), APP_KEY, and DATABASE_URL (or DB_URL).
# Vercel usually sets VERCEL=1 — the app uses stderr logging, array cache, and /tmp for compiled views
# (the serverless filesystem is not writable like a normal VPS). If you still see 500s, add
# VERCEL=1 in Vercel → Settings → Environment Variables (all environments).
# Without a reachable DB, routes that query the database (e.g. /) will return 500.
#
# Vercel checklist (Project → Settings → Environment Variables):
# - APP_KEY=base64:...     (run: php artisan key:generate --show)
# - APP_ENV=production
# - APP_DEBUG=false        (set true briefly only to read the real error, then false)
# - APP_URL=https://your-deployment.vercel.app
# - DATABASE_URL=postgresql://...  (must be reachable from the public internet; Neon recommended)
# - SESSION_DRIVER=cookie      (recommended; see ALLOW_VERCEL_DATABASE_DRIVERS below)
# - CACHE_STORE=array
# - LOG_CHANNEL=stderr         (see errors under Vercel → Deployment → Functions → Logs)
# The app auto-switches to cookie session + array cache + sync queue on Vercel (detected via VERCEL or
# VERCEL_URL) unless you set ALLOW_VERCEL_DATABASE_DRIVERS=true — so old “database” values in Vercel
# env stop taking the whole site down when the primary database blips.
# After changing env: redeploy. Run migrations against production DB from your machine: php artisan migrate
#
# --- Why register / mapi / listings return 500 on Vercel (often mistaken for “app bugs”) ---
# Laravel opens a DB connection on those requests. If the DB is unreachable, tables are missing, or SSL
# fails, PHP throws → generic 500. Check Vercel → Deployment → Functions / Runtime logs for SQLSTATE or SSL errors.
#
# --- Managed PostgreSQL (pick one) ---
# Neon (+ Vercel Postgres), Supabase, Railway Postgres, DigitalOcean Managed PG, AWS RDS Postgres, Aiven Postgres.
# Open the DB firewall to the internet (e.g. 0.0.0.0/0) or your host’s serverless egress IPs so Vercel can connect.

# Optional: iOS App Store or TestFlight URL. When set, /download shows "Get on App Store" for iOS.
# APP_IOS_STORE_URL=https://apps.apple.com/app/homemart/id123456789
# Native Android (Kotlin) — Play Store listing for /download page
# APP_ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=dev.tint_wym.homemart
# Or TestFlight: https://testflight.apple.com/join/XXXXXXXX

# Fallback region when IP is local/private or geolocation fails. Live traffic: GPS cookie → IP → this.
# See App\Services\RegionFromIp.
SHOP_REGION=MM
# Set false to skip browser GPS cookie (Nominatim reverse geocode). Default true.
# SHOP_GPS_REGION_ENABLED=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Set to 1 only when intentionally running migrate:fresh / db:wipe against production. Unset after.
# ALLOW_DESTRUCTIVE_DB_COMMANDS=0

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database: PostgreSQL ---
# Local: install PostgreSQL, create database `homemart`, then migrate. Optional: use Neon and paste DATABASE_URL for both local + Vercel.
# Tests (phpunit) still use SQLite in-memory — no Postgres required to run `composer test`.
#
# Option A — discrete variables (typical local Postgres):
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=homemart
DB_USERNAME=postgres
DB_PASSWORD=
# DB_SSLMODE=prefer
#
# Option B — single URI (Neon / Vercel; can unset DB_* or leave them — URL takes precedence when set):
# DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
#
# Neon: hostnames containing "-pooler" use PgBouncer. If migrations fail (e.g. SQLSTATE 25P02 / primary key errors),
# either use the "direct" connection string (non-pooler host from Neon dashboard) for `php artisan migrate`,
# or keep pooler URLs — migrations in this repo set $withinTransaction = false for compatibility with poolers.
# Prepared-statement / plan cache issues (e.g. "cached plan must not change result type"): leave
# DB_PGSQL_EMULATE_PREPARES unset (defaults to true) or set DB_PGSQL_EMULATE_PREPARES=true.
#
# Vercel: set DATABASE_URL to your Neon connection string; set DB_CONNECTION=pgsql or omit it (inferred from URL).
# After deploy: php artisan migrate --force from any machine that can reach the DB.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Listing images: "public" = local (storage/app/public/listings); "s3" = AWS (set AWS_*);
# "cloudinary" = Cloudinary (set CLOUDINARY_* below).
LISTING_FILESYSTEM_DISK=public

# Cloudinary (when LISTING_FILESYSTEM_DISK=cloudinary). Get from https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Stripe (checkout + saved cards for all regions except Myanmar – https://dashboard.stripe.com/apikeys)
# Use STRIPE_KEY or STRIPE_PUBLISHABLE_KEY for the publishable key.
# After adding keys, run: php artisan config:clear
STRIPE_KEY=
STRIPE_SECRET=

# 2C2P (Myanmar checkout only – https://developer.2c2p.com)
# Sandbox token URL default is used if C2C2P_PAYMENT_TOKEN_URL is unset.
C2C2P_MERCHANT_ID=
C2C2P_SECRET_KEY=
# C2C2P_PAYMENT_TOKEN_URL=https://pgw.2c2p.com/payment/4.3/paymentToken
C2C2P_PAYMENT_TOKEN_URL=https://sandbox-pgw.2c2p.com/payment/4.3/paymentToken