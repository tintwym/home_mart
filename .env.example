APP_NAME="Home Mart"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# For local dev use http://127.0.0.1:8000 (php artisan serve is HTTP-only).
# In production use https:// (e.g. https://your-domain.com).
APP_URL=http://127.0.0.1:8000

# Vercel / production: set APP_URL (https://…), APP_KEY, and DATABASE_URL (or DB_URL).
# Vercel usually sets VERCEL=1 — the app uses stderr logging, array cache, and /tmp for compiled views
# (the serverless filesystem is not writable like a normal VPS). If you still see 500s, add
# VERCEL=1 in Vercel → Settings → Environment Variables (all environments).
# Without a reachable DB, routes that query the database (e.g. /) will return 500.
#
# Vercel checklist (Project → Settings → Environment Variables):
# - APP_KEY=base64:...     (run: php artisan key:generate --show)
# - APP_ENV=production
# - APP_DEBUG=false        (set true briefly only to read the real error, then false)
# - APP_URL=https://your-deployment.vercel.app
# - DATABASE_URL=mysql://...   (Aiven: Network → allow 0.0.0.0/0 so Vercel’s dynamic IPs can connect)
# - SESSION_DRIVER=cookie      (recommended; see ALLOW_VERCEL_DATABASE_DRIVERS below)
# - CACHE_STORE=array
# - LOG_CHANNEL=stderr         (see errors under Vercel → Deployment → Functions → Logs)
# The app auto-switches to cookie session + array cache + sync queue on Vercel (detected via VERCEL or
# VERCEL_URL) unless you set ALLOW_VERCEL_DATABASE_DRIVERS=true — so old “database” values in Vercel
# env stop taking the whole site down when MySQL blips.
# After changing env: redeploy. Run migrations against Aiven from your machine: php artisan migrate

# Optional: iOS App Store or TestFlight URL. When set, /download shows "Get on App Store" for iOS.
# APP_IOS_STORE_URL=https://apps.apple.com/app/homemart/id123456789
# Native Android (Kotlin) — Play Store listing for /download page
# APP_ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=dev.tint_wym.homemart
# Or TestFlight: https://testflight.apple.com/join/XXXXXXXX

# Shop region for navbar locations (e.g. MM=Myanmar, US=United States). See config/shop.php.
SHOP_REGION=SG

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Set to 1 only when intentionally running migrate:fresh / db:wipe (e.g. against Aiven). Unset after.
# ALLOW_DESTRUCTIVE_DB_COMMANDS=0

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Local development: use SQLite so the app works without a remote DB. ---
# Set APP_ENV=local and leave DATABASE_URL unset (or comment it out). This avoids
# 500 errors when the remote MySQL host (e.g. Aiven) is unreachable from your machine.
DB_CONNECTION=sqlite
# DATABASE_URL=  # leave unset for local; set only for production (e.g. Vercel/Railway/Render + managed DB)

# For Aiven (MySQL or PostgreSQL), set DATABASE_URL to the service connection URI.
# The app auto-selects mysql or pgsql from the URL scheme. For Aiven MySQL:
# 1. Download the CA certificate from Aiven console (Service → Overview) and save as storage/app/ca.pem
# 2. Or set MYSQL_ATTR_SSL_CA to the full path to the CA file
# 3. If you get "Cannot connect to MySQL using SSL", try MYSQL_ATTR_SSL_VERIFY_SERVER_CERT=false (less secure)
# DATABASE_URL="mysql://user:password@host:port/defaultdb?ssl-mode=REQUIRED"
# MYSQL_ATTR_SSL_VERIFY_SERVER_CERT=false
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Listing images: "public" = local (storage/app/public/listings); "s3" = AWS (set AWS_*);
# "cloudinary" = Cloudinary (set CLOUDINARY_* below).
LISTING_FILESYSTEM_DISK=public

# Cloudinary (when LISTING_FILESYSTEM_DISK=cloudinary). Get from https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Stripe (for checkout and Payment method in Singapore – https://dashboard.stripe.com/apikeys)
# Use STRIPE_KEY or STRIPE_PUBLISHABLE_KEY for the publishable key.
# After adding keys, run: php artisan config:clear
STRIPE_KEY=
STRIPE_SECRET=
